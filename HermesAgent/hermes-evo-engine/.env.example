# ── LLM ────────────────────────────────────────────────────────────────
HERMES_MODEL_NAME=qwen-max
HERMES_MODEL_API_KEY=your-api-key-here
HERMES_MODEL_API_URL=

# ── TDSQL (MySQL 兼容) ───────────────────────────────────────────────
HERMES_DATABASE_URL=mysql+aiomysql://hermes:hermes@localhost:3306/hermes_evo

# ── Redis ──────────────────────────────────────────────────────────────
HERMES_REDIS_URL=redis://localhost:6379/0

# ── Skill Store ────────────────────────────────────────────────────────
HERMES_SKILL_STORE_PATH=./skill_store

# ── 双引擎参数 ─────────────────────────────────────────────────────────
HERMES_REVIEW_THRESHOLD=10
HERMES_MAX_AGENT_ITERS=20

# ── 安全 ──────────────────────────────────────────────────────────────
HERMES_SAFETY_SCAN_ENABLED=true

# ── Agent 池 ──────────────────────────────────────────────────────────
HERMES_AGENT_POOL_SIZE=5

# ── 日志 ──────────────────────────────────────────────────────────────
HERMES_LOG_LEVEL=INFO
HERMES_DEBUG=false
